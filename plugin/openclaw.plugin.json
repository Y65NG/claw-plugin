{
  "id": "claw-control-center",
  "name": "Claw Control Center",
  "description": "QClaw/OpenClaw multi-session control plugin with a local web console.",
  "activation": {
    "onStartup": true
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "gateway": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "baseUrl": {
            "type": "string",
            "description": "Custom gateway base URL, for example https://gateway.example.com/v1"
          },
          "botId": {
            "type": "string"
          },
          "secret": {
            "type": "string"
          },
          "requestTimeoutMs": {
            "type": "number",
            "default": 15000
          },
          "streamReconnectMs": {
            "type": "number",
            "default": 2000
          },
          "preferResponsesApi": {
            "type": "boolean",
            "default": false,
            "description": "When enabled, prefer Gateway HTTP POST /v1/responses SSE for local runs; otherwise use the WebSocket RPC path by default."
          },
          "modelOverride": {
            "type": "string",
            "description": "Optional model id sent as x-openclaw-model when using the HTTP /v1/responses API."
          }
        }
      },
      "hub53ai": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "botId": {
            "type": "string",
            "description": "53AIHub Bot ID."
          },
          "secret": {
            "type": "string",
            "description": "53AIHub App Secret / Token."
          },
          "wsUrl": {
            "type": "string",
            "description": "53AIHub WebSocket URL, for example wss://example.com/api/v1/openclaw/ws/connect"
          },
          "accessPolicy": {
            "type": "string",
            "enum": [
              "open",
              "allowlist"
            ],
            "default": "open"
          },
          "allowFrom": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "sendThinkingMessage": {
            "type": "boolean",
            "default": true
          },
          "diagnosticLogs": {
            "type": "boolean",
            "default": false,
            "description": "Enable concise 53AIHub diagnostic logs without logging message bodies."
          },
          "ledgerDebug": {
            "type": "boolean",
            "default": false,
            "description": "Enable canonical OpenClaw ledger transition logs without logging message bodies."
          },
          "duplicateTrace": {
            "type": "boolean",
            "default": false,
            "description": "Enable duplicate and stale-event trace logs without logging message bodies."
          },
          "debug": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "all": {
                "type": "boolean",
                "default": false
              },
              "ledger": {
                "type": "boolean",
                "default": false
              },
              "duplicates": {
                "type": "boolean",
                "default": false
              }
            }
          },
          "reconnectBaseMs": {
            "type": "number",
            "default": 2000
          },
          "maxReconnectAttempts": {
            "type": "number",
            "default": 10
          },
          "detectCreatedFiles": {
            "type": "boolean",
            "default": false,
            "description": "When true, enable the legacy fallback that scans local workspace directories when the per-conversation output manifest has no matching files."
          },
          "fileWorkspaceDirs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Optional workspace directories to scan for newly created output files. Inferred QClaw/OpenClaw workspaces are also used when available."
          },
          "createdFilesMaxFileBytes": {
            "type": "number",
            "default": 10485760
          },
          "createdFilesMaxCount": {
            "type": "number",
            "default": 20
          },
          "createdFilesExclude": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Glob-like path patterns excluded from local output file detection."
          }
        }
      },
      "console": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "host": {
            "type": "string",
            "default": "127.0.0.1"
          },
          "port": {
            "type": "number",
            "default": 4318
          },
          "showRawThinking": {
            "type": "boolean",
            "default": true,
            "description": "When true, display raw model thinking/reasoning fields returned by OpenClaw/QClaw in the local console."
          }
        }
      },
      "persistence": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "maxSessions": {
            "type": "number",
            "default": 100
          }
        }
      },
      "logging": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "level": {
            "type": "string",
            "enum": [
              "debug",
              "info",
              "warn",
              "error"
            ],
            "default": "info"
          }
        }
      }
    }
  }
}
