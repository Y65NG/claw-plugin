{
  "id": "53ai-openclaw",
  "channels": [
    "53aihub"
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "botId": {
        "type": "string",
        "description": "53AIHub 智能体 ID (HashID)"
      },
      "secret": {
        "type": "string",
        "description": "53AIHub App Secret / Token"
      },
      "token": {
        "type": "string",
        "description": "53AIHub App Secret / Token (Alias)"
      },
      "WSUrl": {
        "type": "string",
        "description": "53AIHub WebSocket 连接地址"
      },
      "accessPolicy": {
        "type": "string",
        "enum": [
          "open",
          "allowlist",
          "pairing"
        ],
        "default": "open",
        "description": "访问策略: open=开放所有用户, allowlist=仅白名单用户, pairing=首次使用需审批"
      },
      "allowFrom": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "访问控制白名单，配合 accessPolicy=allowlist 或 pairing 使用"
      }
    }
  }
}